{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sim Racing Engineer",
  "version": "1.0.0",
  "identifier": "com.simracing.engineer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sim Racing Engineer",
        "width": 1400,
        "height": 850,
        "minWidth": 1100,
        "minHeight": 650
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwMUQ0QTIwMjQyNEYyQTMKUldTajhpUWtJRW9kTUw3TWY1SVhUam5WTTZXb3Q3VnRmdDdSOXVISWZqVExFL21qeWwrVWEvaXMK",
      "endpoints": [
        "https://github.com/schmidiiii/sim-racing-engineer/releases/latest/download/latest.json"
      ]
    }
  }
}
