{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sim Racing Engineer",
  "version": "1.0.4",
  "identifier": "com.simracing.engineer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1400,
        "height": 850,
        "minWidth": 1100,
        "minHeight": 650,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDNkVBRjhEQTUxMjYxQUYKUldTdllSS2xqYTl1ekd5dFRMNSs3RkVRMUZGNzgxTUN2TXYybzVSbkNHRHlZMzZ0Zzlmb1ZPNjYK",
      "endpoints": [
        "https://github.com/schmidiiii/sim-racing-engineer/releases/latest/download/latest.json"
      ]
    }
  }
}
